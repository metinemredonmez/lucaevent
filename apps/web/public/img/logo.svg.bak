<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <defs>
    <radialGradient id="ring" cx="50%" cy="45%" r="50%">
      <stop offset="0%" stop-color="#F4C7A8"/>
      <stop offset="60%" stop-color="#E8A07D"/>
      <stop offset="100%" stop-color="#B56742"/>
    </radialGradient>
    <path id="top" d="M 30 100 A 70 70 0 0 1 170 100"/>
    <path id="bottom" d="M 30 100 A 70 70 0 0 0 170 100"/>
  </defs>

  <!-- background circle -->
  <circle cx="100" cy="100" r="82" fill="url(#ring)" stroke="#2A1910" stroke-width="1.5"/>

  <!-- planet ring -->
  <ellipse cx="100" cy="100" rx="68" ry="16" fill="none" stroke="#2A1910" stroke-width="2" stroke-dasharray="2 3" opacity="0.55"/>

  <!-- dots / stars scattered -->
  <circle cx="60" cy="78" r="1.6" fill="#FFF6EC"/>
  <circle cx="145" cy="72" r="1.2" fill="#FFF6EC"/>
  <circle cx="130" cy="135" r="1.4" fill="#FFF6EC"/>
  <circle cx="72" cy="132" r="1" fill="#FFF6EC"/>

  <!-- central sphere -->
  <circle cx="100" cy="100" r="28" fill="#F4C7A8" stroke="#2A1910" stroke-width="1"/>
  <circle cx="92" cy="92" r="6" fill="#FFF6EC" opacity="0.7"/>

  <!-- NOVARA top -->
  <text font-family="Georgia, 'Newsreader', serif" font-size="18" font-weight="700" fill="#2A1910" letter-spacing="4">
    <textPath href="#top" startOffset="50%" text-anchor="middle">NOVARA</textPath>
  </text>

  <!-- NETWORK bottom -->
  <text font-family="Georgia, 'Newsreader', serif" font-size="15" font-weight="700" fill="#2A1910" letter-spacing="3">
    <textPath href="#bottom" startOffset="50%" text-anchor="middle">NETWORK</textPath>
  </text>
</svg>
