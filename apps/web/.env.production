# Production frontend env.
# NEXT_PUBLIC_* değerleri `next build` sırasında client JS'e gömülür (gizli DEĞİL).
# Prod API subdomain'de yayında: https://api.lucaclub.com.tr  → BASE = .../api/v1
NEXT_PUBLIC_API_URL=https://api.lucaclub.com.tr

# OneSignal web-push App ID (public; secret REST API Key admin Ayarlar'da).
NEXT_PUBLIC_ONESIGNAL_APP_ID=d5fad9f5-c827-4650-8590-8e10e5a2b51a
