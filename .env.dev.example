# ---- Luca root env ----
# Kurulum: `cp .env.dev.example .env.dev`

# ---- apps/api ----
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
WEB_URL=http://localhost:3000

DATABASE_URL=postgresql://luca:luca@localhost:55432/luca_dev
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=dev-access-change-me-please
JWT_REFRESH_SECRET=dev-refresh-change-me-please
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Mail (CyberPanel sunucusunun SMTP'si)
SMTP_HOST=mail.luca.club
SMTP_PORT=587
SMTP_USER=no-reply@luca.club
SMTP_PASSWORD=
SMTP_FROM="Luca <no-reply@luca.club>"
SMTP_SECURE=false   # 587 → false (STARTTLS) | 465 → true (TLS)

# MinIO (lokal S3 alternatifi)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=luca-dev
S3_ACCESS_KEY=luca
S3_SECRET_KEY=luca-dev-secret
S3_PUBLIC_URL=http://localhost:9000/luca-dev
S3_REGION=us-east-1

# Ödeme (rezervasyon / üyelik için ileride)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
IYZICO_API_KEY=sandbox-
IYZICO_SECRET=sandbox-

# Google Sign-In — OAuth client id(ler). Birden fazla için virgülle ayır
# (web,ios,android). Client Google ile giriş yapıp idToken'ı POST /auth/google'a yollar.
GOOGLE_CLIENT_ID=

# OneSignal push (REST). ONESIGNAL_API_KEY = REST API Key (Basic auth).
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

SENTRY_DSN=
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3000

# ---- apps/web ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
AUTH_SECRET=dev-auth-change-me
AUTH_URL=http://localhost:3000

# WhatsApp → etkinlik ingest (opsiyonel; anahtarsız regex fallback çalışır)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
WA_WEBHOOK_SECRET=

# Google Places (opsiyonel — yoksa mekanlar DB verisiyle çalışır)
GOOGLE_PLACES_API_KEY=

PEXELS_API_KEY=
