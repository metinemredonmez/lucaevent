# Luca production env — sunucuda .env.prod olarak kopyala
# ASLA git'e commit'leme (.gitignore'da zaten engellendi)
#
# Sunucuya gönderirken:
#   scp .env.prod root@YOUR_SERVER_IP:/var/www/luca/.env.prod
#   chmod 600 /var/www/luca/.env.prod

NODE_ENV=production

# Portlar (CyberPanel sunucusundaki diğer projelerle çakışmasın)
PORT=3019                                    # API portu
WEB_PORT=3009                                # Web portu

APP_URL=https://api.lucaclub.com.tr
WEB_URL=https://lucaclub.com.tr

# ----- Database (Docker'da, sadece localhost'tan erişilir) -----
# docker-compose.prod.yml içinde 127.0.0.1:55433 → 5432 mapping
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_here
DATABASE_URL=postgresql://luca_prod:CHANGE_ME_strong_db_password_here@127.0.0.1:55433/luca_prod

# ----- Redis (Docker, sadece localhost) -----
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_URL=redis://default:CHANGE_ME_strong_redis_password@127.0.0.1:56380

# ----- JWT — KESİNLİKLE RANDOM güçlü, en az 48 karakter -----
# Oluşturmak için: openssl rand -base64 48
JWT_ACCESS_SECRET=CHANGE_ME_run_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_run_openssl_rand_base64_48_again
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ----- Mail (CyberPanel'in mail sunucusu - mail.lucaclub.com.tr) -----
# CyberPanel → Email → Create Email account oluştur, şifresini buraya yaz
SMTP_HOST=mail.lucaclub.com.tr
SMTP_PORT=587
SMTP_USER=no-reply@lucaclub.com.tr
SMTP_PASSWORD=CHANGE_ME_cyberpanel_mail_password
SMTP_FROM="Luca <no-reply@lucaclub.com.tr>"
SMTP_SECURE=false

# ----- S3 / R2 (medya yükleme - opsiyonel) -----
S3_ENDPOINT=
S3_BUCKET=luca-prod
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=https://cdn.lucaclub.com.tr
S3_REGION=auto

# ----- Ödeme (rezervasyon/üyelik için) -----
STRIPE_SECRET_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_
IYZICO_API_KEY=
IYZICO_SECRET=

# ----- Telemetri & log -----
SENTRY_DSN=
LOG_LEVEL=info
CORS_ORIGINS=https://lucaclub.com.tr,https://www.lucaclub.com.tr

# ----- Frontend (Next.js public env) -----
NEXT_PUBLIC_SITE_URL=https://lucaclub.com.tr
NEXT_PUBLIC_API_URL=https://api.lucaclub.com.tr
AUTH_SECRET=CHANGE_ME_openssl_rand_base64_32
AUTH_URL=https://lucaclub.com.tr

# Google Sign-In
GOOGLE_CLIENT_ID=

# OneSignal push
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
